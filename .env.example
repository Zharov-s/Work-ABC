# Скопируйте этот файл в .env для локального запуска
# На Railway эти переменные задаются в Settings → Variables

# API ключи (обязательно)
OPENAI_API_KEY=sk-proj-...
TAVILY_API_KEY=tvly-dev-...

# Flask (обязательно на Railway)
SECRET_KEY=замените-на-случайную-строку
FLASK_ENV=production

# SMTP (можно задать здесь или через интерфейс Настройки)
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_USER=s.zharov@abcentrum.ru
# SMTP_PASS=пароль_приложения
