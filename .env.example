# Скопируйте этот файл в .env для локального запуска
# На Railway эти переменные задаются в Settings → Variables

# Tavily API (веб-поиск для Research)
TAVILY_API_KEY=tvly-dev-...

# Flask
SECRET_KEY=замените-на-случайную-строку
FLASK_ENV=production

# AI для Research: Ollama запускается локально, ключи не нужны
# Убедитесь что Ollama запущен: ollama serve
# Модель по умолчанию: qwen3:4b
